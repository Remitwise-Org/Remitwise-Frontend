{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "vitest.setup.ts",
    "vitest-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
