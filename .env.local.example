# Stellar Network Configuration
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK=testnet

# Soroban Contract Addresses
NEXT_PUBLIC_SAVINGS_GOALS_CONTRACT_ID=your_contract_id_here

# Server-side contract resolution (remittance split)
REMITTANCE_SPLIT_CONTRACT_ID_TESTNET=your_testnet_contract_id_here
REMITTANCE_SPLIT_CONTRACT_ID_MAINNET=your_mainnet_contract_id_here
# Alternative to per-network env vars:
# CONTRACT_IDS_JSON={"testnet":{"REMITTANCE_SPLIT_CONTRACT_ID":"<id>"},"mainnet":{"REMITTANCE_SPLIT_CONTRACT_ID":"<id>"}}
